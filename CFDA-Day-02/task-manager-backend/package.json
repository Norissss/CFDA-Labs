{
  "name": "task-manager-backend",
  "version": "1.0.0",
  "description": "REST API backend untuk aplikasi Task Manager React menggunakan Node.js, Express, dan PostgreSQL.",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:init": "node scripts/init-db.js",
    "test": "node --test"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "task-manager",
    "rest-api"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
